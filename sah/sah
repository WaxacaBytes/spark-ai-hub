def _prepare_hermes_home(model: str) -> Path:
    """Build an isolated HERMES_HOME for `sah hermes` that mirrors the user's
    real ~/.hermes/ via symlinks, with config.yaml materialized fresh.

    Hermes reads model.base_url from config.yaml (no CLI flag overrides it),
    so we need a sah-owned config. But the user's real ~/.hermes/ also holds
    skills, sessions, memories, providers, personalities, etc. — symlinking
    every other child through means ephemeral `sah hermes` still sees all of
    that, only the model block is overridden to point at the Hub.
    """
    home = CONFIG_DIR / "hermes-home"
    home.mkdir(parents=True, exist_ok=True)

    OWNED = {"config.yaml"}
    real = Path.home() / ".hermes"
    if real.is_dir():
        existing = {p.name: p for p in home.iterdir()}
        wanted = {p.name for p in real.iterdir() if p.name not in OWNED}
        for name, link in existing.items():
            if name in OWNED:
                continue
            if link.is_symlink() and name not in wanted:
                link.unlink()
        for item in real.iterdir():
            if item.name in OWNED:
                continue
            link = home / item.name
            target = item.resolve()
            if link.is_symlink():
                if Path(os.readlink(link)) == target:
                    continue
                link.unlink()
            elif link.exists():
                continue  # leave non-symlink user data alone
            link.symlink_to(target)

    real_cfg = real / "config.yaml"
    base_text = real_cfg.read_text() if real_cfg.is_file() else ""
    new_text = _replace_yaml_top_block(base_text, "model", _hermes_model_block(model))
    _write_text_atomic(home / "config.yaml", new_text)
    return home


def _hermes_config_path() -> Path:
    return Path.home() / ".hermes" / "config.yaml"


def _hermes_model_block(model: str) -> str:
    return (
        f"model:\n"
        f"  default: {model}\n"
        f"  provider: custom\n"
        f"  base_url: {api_base()}\n"
    )


def _replace_yaml_top_block(text: str, key: str, block: str) -> str:
    """Replace the top-level YAML mapping `key:` block (key + indented children)
    with `block` (which must start with `key:` and end with a newline). If the
    key isn't present, prepend the block. Other top-level keys are preserved."""
    lines = text.splitlines()
    head = re.compile(rf"^{re.escape(key)}\s*:\s*(?:#.*)?$")
    start = next((i for i, ln in enumerate(lines) if head.match(ln)), None)
    if start is None:
        prefix = block if text.endswith("\n") or not text else block
        return prefix + text
    end = start + 1
    while end < len(lines) and (lines[end] == "" or lines[end][:1] in (" ", "\t")):
        end += 1
    new_lines = lines[:start] + block.rstrip("\n").splitlines() + lines[end:]
    out = "\n".join(new_lines)
    if not out.endswith("\n"):
        out += "\n"
    return out


