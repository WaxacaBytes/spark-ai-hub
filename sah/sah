def cmd_opencode(args) -> None:
    if args.status:
        _status_opencode_global()
        return
    if args.restore:
        _restore_client_file("opencode", _opencode_config_path())
        return
    if not shutil.which("opencode"):
        sys.exit("opencode not found in PATH. Install options: https://opencode.ai")
    model = require_model()
    config = _opencode_hub_config(model)
    if args.install:
        _install_opencode_global(model)
        return
    env = {**os.environ, "OPENCODE_CONFIG_CONTENT": json.dumps(config)}
    os.execvpe("opencode", ["opencode", *_normalize_passthrough(args.passthrough)], env)


def _opencode_config_path() -> Path:
    return Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "opencode" / "opencode.json"


def _opencode_hub_config(model: str, base: dict | None = None) -> dict:
    config = base if isinstance(base, dict) else {}
    config["$schema"] = "https://opencode.ai/config.json"
    model_cfg = {"name": model}
    inputs = _opencode_input_modalities_for(model)
    if len(inputs) > 1:
        model_cfg["attachment"] = True
        model_cfg["modalities"] = {"input": inputs, "output": ["text"]}
    providers = config.get("provider") if isinstance(config.get("provider"), dict) else {}
    providers["sah"] = {
        "npm": "@ai-sdk/openai-compatible",
        "name": "Spark AI Hub",
        "options": {"baseURL": api_base()},
        "models": {model: model_cfg},
    }
    config["provider"] = providers
    config["model"] = f"sah/{model}"
    return config


def _install_opencode_global(model: str) -> None:
    path = _opencode_config_path()
    _backup_client_file_once("opencode", path)
    config = _read_json(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    _write_json_atomic(path, _opencode_hub_config(model, config))
    _print_wired("OpenCode", "opencode", path)


def _status_opencode_global() -> None:
    path = _opencode_config_path()
    config = _read_json(path)
    provider = (config.get("provider") or {}).get("sah") if isinstance(config.get("provider"), dict) else None
    wired = config.get("model", "").startswith("sah/") and isinstance(provider, dict)
    _print_status("OpenCode", "opencode", path, wired)


def _opencode_input_modalities_for(model: str) -> list[str]:
    inputs = ["text"]
    mods = _qwen_modalities_for(model)
    if mods.get("image"):
        inputs.append("image")
    if mods.get("video"):
        inputs.append("video")
    if mods:
        inputs.append("pdf")
    return inputs


def cmd_codex(args) -> None:
    if args.status:
        _status_codex_global()
        return
    if args.restore:
        _restore_client_file("codex", _codex_config_path())
        return
    if not shutil.which("codex"):
        sys.exit("codex not found in PATH. Install options: https://github.com/openai/codex")
    info = current_model_info()
    if not info:
        sys.exit(
            f"No model is running on {hub_url()}.\n"
            f"Launch one from the Spark AI Hub web UI first."
    )
    model = info["id"]
    if args.install:
        _install_codex_global(model, info)
        return
    catalog_path = _write_codex_catalog(model, info)
    env = {**os.environ, "OPENAI_API_KEY": "sah"}
    extra = _normalize_passthrough(args.passthrough)
    common = ["-m", model, *_codex_hub_config_args()]
    if catalog_path:
        common += ["-c", f'model_catalog_json="{catalog_path}"']
    elif ctx := info.get("max_model_len"):
        common += ["-c", f"model_context_window={int(ctx)}"]
    if extra and extra[0] == "exec":
        exec_args, prompt = _split_codex_exec_prompt(extra[1:])
        if prompt is not None:
            prompt = _augment_codex_pdf_text(prompt)
            cmd = ["codex", "exec", *common, *exec_args, "-"]
            sys.exit(subprocess.run(cmd, env=env, input=prompt, text=True).returncode)
        cmd = ["codex", "exec", *common, *exec_args]
    else:
        cmd = ["codex", *common, *extra]
    os.execvpe("codex", cmd, env)


def _write_codex_catalog(model: str, info: dict) -> str | None:
    """Fetch the catalog template from the Hub, repoint to the live model,
    write to ~/.config/sah/codex-catalog.json. Returns the absolute path or None.
    """
    try:
        with urllib.request.urlopen(f"{hub_url()}/sah/codex-model-template.json", timeout=2) as r:
            tpl = json.loads(r.read())
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        return None
    if not (tpl.get("models") and isinstance(tpl["models"], list)):
        return None
    entry = tpl["models"][0]
    entry["slug"] = model
    entry["display_name"] = model
    entry["input_modalities"] = _codex_input_modalities_for(model)
    if ctx := info.get("max_model_len"):
        entry["context_window"] = int(ctx)
        entry["max_context_window"] = int(ctx)
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    out = CONFIG_DIR / "codex-catalog.json"
    _write_text_atomic(out, json.dumps(tpl))
    return str(out)


def _codex_config_path() -> Path:
    return Path.home() / ".codex" / "config.toml"


def _codex_hub_config_args() -> list[str]:
    base = api_base().rstrip("/") + "/"
    return [
        "-c", 'model_provider="sah"',
        "-c", 'forced_login_method="api"',
        "-c", 'model_providers.sah.name="Spark AI Hub"',
        "-c", f'model_providers.sah.base_url="{base}"',
    ]


def _install_codex_global(model: str, info: dict) -> None:
    cfg = _codex_config_path()
    _backup_client_file_once("codex", cfg)
    _ensure_codex_profile()
    catalog_path = _write_codex_catalog(model, info)
    text = cfg.read_text() if cfg.is_file() else ""
    text = _set_toml_top_level_string(text, "model", model)
    text = _set_toml_top_level_string(text, "model_provider", "sah")
    text = _set_toml_top_level_string(text, "forced_login_method", "api")
    if catalog_path:
        text = _set_toml_top_level_string(text, "model_catalog_json", catalog_path)
    elif ctx := info.get("max_model_len"):
        text = _set_toml_top_level_value(text, "model_context_window", str(int(ctx)))
    cfg.parent.mkdir(parents=True, exist_ok=True)
    _validate_toml_text(text, cfg)
    _write_text_atomic(cfg, text)
    _print_wired("Codex", "codex", cfg)


def _status_codex_global() -> None:
    cfg = _codex_config_path()
    text = cfg.read_text() if cfg.is_file() else ""
    top = text.split("\n[", 1)[0]
    wired = 'model_provider = "sah"' in top
    _print_status("Codex", "codex", cfg, wired)


def _set_toml_top_level_string(text: str, key: str, value: str) -> str:
    escaped = value.replace("\\", "\\\\").replace('"', '\\"')
    return _set_toml_top_level_value(text, key, f'"{escaped}"')


def _set_toml_top_level_value(text: str, key: str, value: str) -> str:
    split = text.split("\n[", 1)
    top = split[0]
    rest = "\n[" + split[1] if len(split) > 1 else ""
    pattern = re.compile(rf"(?m)^{re.escape(key)}\s*=.*$")
    line = f"{key} = {value}"
    if pattern.search(top):
        top = pattern.sub(line, top)
    else:
        top = (top.rstrip() + "\n" + line + "\n").lstrip("\n")
    return top + rest


def _validate_toml_text(text: str, path: Path) -> None:
    if tomllib is None:  # no TOML parser available (Python < 3.11, no tomli)
        return
    try:
        tomllib.loads(text)
    except tomllib.TOMLDecodeError as exc:
        sys.exit(f"Refusing to write invalid TOML to {path}: {exc}")


