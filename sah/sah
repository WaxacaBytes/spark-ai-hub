        "HERMES_HOME": str(hermes_home),
        "OPENAI_API_KEY": "sah",
        "OPENAI_BASE_URL": api_base(),
    }
    extra = _normalize_passthrough(args.passthrough)
    launch_args = ["desktop"]
    if _hermes_desktop_skip_build(extra):
        launch_args.append("--skip-build")
    os.execvpe("hermes", ["hermes", *launch_args, *extra], env)


def _hermes_desktop_skip_build(extra: list[str]) -> bool:
    """True when sah should pass --skip-build to `hermes desktop`: a packaged
    desktop app already exists and the user didn't pass a build/help flag of
    their own. Mirrors Ollama's HermesDesktop.shouldSkipDesktopBuild."""
    for arg in extra:
        if arg == "--":
            break
        if arg in _HERMES_DESKTOP_BUILD_FLAGS:
            return False
    return _hermes_desktop_packaged_app_exists()


def _hermes_desktop_release_roots() -> list[str]:
    """Install roots where Hermes packages its prebuilt desktop app, each joined
    with apps/desktop/release. Mirrors Hermes' own install layout (see
    hermesDesktopReleaseRoots in Ollama). Reads the real environment — call
    before HERMES_HOME is overridden for the ephemeral launch."""
    roots: list[str] = []

    def add(path: str) -> None:
        path = (path or "").strip()
        if path:
            roots.append(os.path.normpath(path))

    add(os.environ.get("HERMES_INSTALL_DIR", ""))
    if hh := os.environ.get("HERMES_HOME", "").strip():
        add(os.path.join(hh, "hermes-agent"))

    home = Path.home()
    if sys.platform == "win32":
        if lad := os.environ.get("LOCALAPPDATA", "").strip():
            add(os.path.join(lad, "hermes", "hermes-agent"))
        add(str(home / ".hermes" / "hermes-agent"))
    else:
        add(str(home / ".hermes" / "hermes-agent"))
        if sys.platform.startswith("linux"):
            add(os.path.join(os.sep, "usr", "local", "lib", "hermes-agent"))

    seen: set[str] = set()
    out: list[str] = []
    for root in roots:
        rel = os.path.join(root, "apps", "desktop", "release")
        if rel in seen:
            continue
        seen.add(rel)
        out.append(rel)
    return out


def _hermes_desktop_packaged_executables(release_root: str) -> list[str]:
    if sys.platform == "darwin":
        return [str(p) for p in Path(release_root).glob("mac*/Hermes.app/Contents/MacOS/Hermes")]
    if sys.platform == "win32":
        return [
            os.path.join(release_root, "win-unpacked", "Hermes.exe"),
            os.path.join(release_root, "win-ia32-unpacked", "Hermes.exe"),
            os.path.join(release_root, "win-arm64-unpacked", "Hermes.exe"),
        ]
    return [
        os.path.join(release_root, "linux-unpacked", "hermes"),
        os.path.join(release_root, "linux-unpacked", "Hermes"),
    ]


def _hermes_desktop_packaged_app_exists() -> bool:
    for root in _hermes_desktop_release_roots():
        for candidate in _hermes_desktop_packaged_executables(root):
            if os.path.exists(candidate):
                return True
    return False


def cmd_qwen(args) -> None:
    if args.status:
        _status_qwen_global()
        return
    if args.restore:
        _restore_qwen_global()
        return
    if not shutil.which("qwen"):
        sys.exit("qwen not found in PATH. Install options: https://github.com/QwenLM/qwen-code")
    model = require_model()
    if args.install:
        _install_qwen_global(model)
        return
    extra = _normalize_passthrough(args.passthrough)
    # Thin-launcher pattern (matches sah claude/codex/etc.): set Hub env vars,
    # pass connection flags, and exec. qwen reads its own config from the
    # user's real ~/.qwen/ — non-invasive by default. Users who want
    # persistent settings.json overrides (e.g. multimodal generationConfig
    # for Qwen 3.5/3.6) use `sah qwen --install`.
    env = {
        **os.environ,
        "OPENAI_API_KEY": "sah",
        "OPENAI_BASE_URL": api_base(),
        # qwen-code caps OpenAI-compatible providers at 8K output tokens
        # (CAPPED_DEFAULT_MAX_TOKENS), truncating large WriteFile/Edit tool
        # calls mid-content. Hub vLLM models serve 262K — lift the cap.
        "QWEN_CODE_MAX_OUTPUT_TOKENS": os.environ.get(
            "QWEN_CODE_MAX_OUTPUT_TOKENS", "65536"
        ),
        # Local Hub vLLM decodes slower than the hosted APIs qwen-code's
        # default timeout assumes, so long turns abort mid-generation with
        # "Request timeout". Lift the per-request timeout (ms) to match; the
        # env override wins unless the user set one or a provider pins its own.
        "QWEN_CODE_API_TIMEOUT_MS": os.environ.get(
            "QWEN_CODE_API_TIMEOUT_MS", "1500000"
        ),
    }
    cmd = [
        "qwen",
        "--auth-type", "openai",
        "--openai-base-url", api_base(),
        "--openai-api-key", "sah",
        "--model", model,
    ]
    # For multimodal Hub models, qwen-code's text-only prior makes it refuse
    # image/video reads even when the modality flag is set in settings.json.
    # Inject a brief capability note via the upstream-supported flag instead
    # of materializing a sandbox QWEN.md.
    if _qwen_modalities_for(model):
        cmd += ["--append-system-prompt", _QWEN_CAPABILITIES_NOTE]
    cmd += extra
    os.execvpe("qwen", cmd, env)



_QWEN_CAPABILITIES_NOTE = """
## Multimodal capabilities (Spark AI Hub)

You are running on a Qwen 3.5/3.6 model served by Spark AI Hub. These models
are natively multimodal: when the `read_file` tool returns image or video
content, you can see and describe it directly. There is no separate "vision
model" to delegate to, and you do not need ffmpeg/ffprobe to inspect a video's
visual content.

When the user asks you to read or describe an image or video file:
- Just call `read_file` with the path. Do not refuse or claim to be text-only.
- Do not suggest extracting frames, running ffprobe, or asking the user to
  describe the file. Read it and answer.
- Supported extensions include common images (png, jpg, jpeg, gif, webp, bmp)
  and videos (mp4, mov, mkv, webm, avi).
""".strip()


def _qwen_modalities_for(model: str) -> dict:
    """Return modality flags for a Hub model.

    Qwen 3.5 / 3.6 instruct + VL families are natively multimodal (image +
    video). qwen-code's built-in defaults only flag `qwen3.5-plus` / `qwen-vl-*`
    as multimodal, so models served by the Hub (e.g. `Qwen/Qwen3.6-35B-A3B-FP8`)
    fall through to the text-only `^qwen` fallback and image/video reads get
    skipped client-side. Mark them multimodal here. Other models get an empty
    map (text-only).
    """
    norm = model.lower().replace("_", "-").split("/")[-1]
    if norm.startswith("qwen3.5") or norm.startswith("qwen3.6"):
        return {"image": True, "video": True}
    if "-vl-" in norm or norm.endswith("-vl") or "vision" in norm:
        return {"image": True, "video": True}
    return {}


