def _add_client_parser(
    sub,
    name: str,
    display: str,
    func,
    *,
    aliases: list[str] | None = None,
    mode: str = "persistent",
):
    sp = sub.add_parser(
        name,
        aliases=aliases or [],
        help=f"Launch {display} through Spark AI Hub",
        description=f"Launch {display} through Spark AI Hub.",
    )
    group = sp.add_mutually_exclusive_group()
    if mode == "persistent":
        group.add_argument(
            "--install",
            action="store_true",
            help=f"Install persistent Spark AI Hub wiring for plain {display}",
        )
        group.add_argument(
            "--restore",
            action="store_true",
            help=f"Restore previous plain {display} settings",
        )
        group.add_argument(
            "--status",
            action="store_true",
            help=f"Show Spark AI Hub wiring status for {display}",
        )
    else:
        group.add_argument(
            "--install",
            action="store_true",
            help=f"Not available: {display} is launch only in sah",
        )
        group.add_argument(
            "--restore",
            action="store_true",
            help=f"Not available: {display} is launch only in sah",
        )
        group.add_argument(
            "--status",
            action="store_true",
            help=f"Show Spark AI Hub support status for {display}",
        )
    sp.add_argument(
        "passthrough",
        nargs=argparse.REMAINDER,
        metavar="args",
        help=f"Arguments passed to {display}",
    )
    sp.set_defaults(func=func)
    return sp


def main() -> None:
    p = argparse.ArgumentParser(
        prog="sah",
        description="Spark AI Hub client launcher",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Lifecycle:\n"
            "  sah <client>              Launch through Spark AI Hub; plain client settings are unchanged\n"
            "  sah <client> --install    Persistent mode: make the plain client use Spark AI Hub\n"
            "  sah <client> --status     Show Spark AI Hub wiring status for the client\n"
            "  sah <client> --restore    Persistent mode: restore the previous plain client settings\n"
            "\n"
            "Client args:\n"
            "  sah <client> -- <args>    Pass args to the underlying client, e.g. sah qwen -- --help\n"
            "\n"
            "Discover integrations:\n"
            "  sah integrations          List each integration's mode and exact lifecycle commands\n"
        ),
    )
    sub = p.add_subparsers(dest="cmd", required=True, title="commands", metavar="<command>")

    sp = sub.add_parser("info", help="Show Hub URL and current model")
    sp.set_defaults(func=cmd_info)

    sp = sub.add_parser("env", help="Print Hub environment variables")
    sp.add_argument("--anthropic", action="store_true", help="Anthropic-shaped env vars")
    sp.set_defaults(func=cmd_env)

    sp = sub.add_parser("integrations", aliases=["clients"],
                        help="List integration modes and lifecycle commands")
    sp.set_defaults(func=cmd_integrations)

    sp = sub.add_parser("set-hub", help="Set the Spark AI Hub URL")
    sp.add_argument("url")
    sp.set_defaults(func=cmd_set_hub)

    _add_client_parser(sub, "opencode", "OpenCode", cmd_opencode)
    _add_client_parser(sub, "codex", "Codex", cmd_codex)
    _add_client_parser(sub, "hermes", "Hermes Agent", cmd_hermes)
    _add_client_parser(sub, "hermes-desktop", "Hermes Desktop", cmd_hermes_desktop)
    _add_client_parser(sub, "qwen", "Qwen Code", cmd_qwen)
    _add_client_parser(sub, "openclaw", "OpenClaw", cmd_openclaw, aliases=["clawdbot", "moltbot"])
    _add_client_parser(sub, "claude", "Claude Code", cmd_claude)

    sp = sub.add_parser("claude-desktop", help="Manage Claude Desktop Spark AI Hub wiring")
    g = sp.add_mutually_exclusive_group()
    g.add_argument("--install", action="store_true",
                   help="Persistently wire Claude Desktop to Spark AI Hub")
    g.add_argument("--restore", action="store_true",
                   help="Restore Claude Desktop to the usual Anthropic profile")
    g.add_argument("--status", action="store_true",
                   help="Show whether SAH is currently wired to Claude Desktop")
    sp.add_argument("--no-restart", action="store_true",
                    help="Skip the automatic Claude Desktop restart")
    sp.set_defaults(func=cmd_claude_desktop)

    args, extras = p.parse_known_args()
    if hasattr(args, "passthrough"):
        args.passthrough = [*extras, *args.passthrough]
