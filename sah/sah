def _model_context_window(info: dict, default: int = 32768) -> int:
    try:
        ctx = int(info.get("max_model_len") or 0)
    except (TypeError, ValueError):
        ctx = 0
    return ctx if ctx > 0 else default


def _mirror_openclaw_profile(profile: str) -> None:
    """Mirror children of the user's main ~/.openclaw/ into ~/.openclaw-<profile>/
    via symlinks so ephemeral `sah openclaw` shares sessions, skills, identity,
    workspace, etc. with plain openclaw. The profile owns its own openclaw.json
    (and the .bak/.last-good siblings openclaw writes alongside it) so the Hub
    wiring stays scoped to the sah profile.
    """
    real = Path.home() / ".openclaw"
    home = _openclaw_state_dir(profile)
    if not real.is_dir():
        return
    home.mkdir(parents=True, exist_ok=True)
    OWNED_PREFIXES = ("openclaw.json",)  # config + .bak / .last-good

    def is_owned(name: str) -> bool:
        return any(name == p or name.startswith(p + ".") for p in OWNED_PREFIXES)

    existing = {p.name: p for p in home.iterdir()}
    wanted = {p.name for p in real.iterdir() if not is_owned(p.name)}
    for name, link in existing.items():
        if is_owned(name):
            continue
        if link.is_symlink() and name not in wanted:
            link.unlink()
    for item in real.iterdir():
        if is_owned(item.name):
            continue
        link = home / item.name
        target = item.resolve()
        if link.is_symlink():
            if Path(os.readlink(link)) == target:
                continue
            link.unlink()
        elif link.exists():
            continue  # leave non-symlink user data alone
        link.symlink_to(target)


def _openclaw_state_dir(profile: str | None = None) -> Path:
    if profile:
        return Path.home() / f".openclaw-{profile}"
    return Path.home() / ".openclaw"


def _openclaw_config_paths(profile: str | None = None) -> tuple[Path, Path]:
    state_dir = _openclaw_state_dir(profile)
    return (
        state_dir / "openclaw.json",
        (Path.home() / ".clawdbot" / "clawdbot.json") if profile is None else state_dir / "clawdbot.json",
    )


def _ensure_openclaw_config(model: str, info: dict, profile: str | None = None) -> None:
    config_path, legacy_path = _openclaw_config_paths(profile)
    if profile is None:
        backup_source = config_path if config_path.is_file() or not legacy_path.is_file() else legacy_path
        _backup_client_file_once("openclaw", backup_source)
    if not config_path.is_file() and not legacy_path.is_file():
        _openclaw_onboard(model, profile=profile)

    source = config_path if config_path.is_file() else legacy_path
    config = _read_json(source)
    config_path.parent.mkdir(parents=True, exist_ok=True)

    models_section = config.setdefault("models", {})
    if not isinstance(models_section, dict):
        models_section = {}
        config["models"] = models_section
    models_section.setdefault("mode", "merge")
    providers = models_section.setdefault("providers", {})
    if not isinstance(providers, dict):
        providers = {}
        models_section["providers"] = providers

    provider = providers.setdefault("sah", {})
    if not isinstance(provider, dict):
        provider = {}
        providers["sah"] = provider
    provider["baseUrl"] = api_base()
    provider["apiKey"] = "sah"
    provider["api"] = "openai-completions"

    model_entry = {
        "id": model,
        "name": model,
        "api": "openai-completions",
        "input": ["text"],
        "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
        "contextWindow": _model_context_window(info),
        "maxTokens": min(8192, _model_context_window(info)),
        "compat": {
            "supportsDeveloperRole": False,
            "supportsUsageInStreaming": True,
            "supportsStrictMode": False,
        },
    }
    existing = provider.get("models") if isinstance(provider.get("models"), list) else []
    provider["models"] = [
        *(m for m in existing if not (isinstance(m, dict) and m.get("id") == model)),
        model_entry,
    ]

    agents = config.setdefault("agents", {})
    if not isinstance(agents, dict):
        agents = {}
        config["agents"] = agents
    defaults = agents.setdefault("defaults", {})
    if not isinstance(defaults, dict):
        defaults = {}
        agents["defaults"] = defaults
    model_config = defaults.setdefault("model", {})
    if not isinstance(model_config, dict):
        model_config = {}
        defaults["model"] = model_config
    model_config["primary"] = f"sah/{model}"

    cfg_models = defaults.setdefault("models", {})
    if isinstance(cfg_models, dict):
        cfg_models[f"sah/{model}"] = cfg_models.get(f"sah/{model}", {})

    _write_json_atomic(config_path, config)
    _clear_openclaw_session_model_override(model, profile=profile)


def _status_openclaw_global() -> None:
    config_path, legacy_path = _openclaw_config_paths()
    source = config_path if config_path.is_file() else legacy_path
    config = _read_json(source)
    primary = (((config.get("agents") or {}).get("defaults") or {}).get("model") or {}).get("primary")
    wired = isinstance(primary, str) and primary.startswith("sah/")
    _print_status("OpenClaw", "openclaw", source, wired)


def _openclaw_onboard(model: str, profile: str | None = None) -> None:
    bin_name = shutil.which("openclaw") or shutil.which("clawdbot")
    cmd = [bin_name]
    if profile:
        cmd += ["--profile", profile]
    cmd += [
        "onboard",
        "--non-interactive",
        "--accept-risk",
        "--auth-choice", "custom-api-key",
        "--custom-provider-id", "sah",
        "--custom-base-url", api_base(),
        "--custom-api-key", "sah",
        "--custom-model-id", model,
        "--custom-compatibility", "openai",
        "--skip-health",
        "--skip-channels",
        "--skip-skills",
        "--skip-ui",
        "--no-install-daemon",
    ]
    result = subprocess.run(cmd, env=_openclaw_env(profile=profile))
    if result.returncode != 0:
        sys.exit("openclaw onboarding failed. Try running: openclaw onboard")


def _clear_openclaw_session_model_override(model: str, profile: str | None = None) -> None:
    path = _openclaw_state_dir(profile) / "agents" / "main" / "sessions" / "sessions.json"
    if not path.is_file():
        return
    try:
        sessions = json.loads(path.read_text())
    except json.JSONDecodeError:
        return
    if not isinstance(sessions, dict):
        return
    changed = False
    for session in sessions.values():
        if not isinstance(session, dict):
            continue
        if session.get("modelOverride") and session.get("modelOverride") != model:
            session.pop("modelOverride", None)
            session.pop("providerOverride", None)
            changed = True
        if session.get("model") and session.get("model") != model:
            session["model"] = model
            changed = True
    if changed:
        _write_json_atomic(path, sessions)


def _openclaw_gateway_info(profile: str | None = None) -> tuple[str, int]:
    token = ""
    port = 18789
    for path in _openclaw_config_paths(profile):
        cfg = _read_json(path)
        gateway = cfg.get("gateway") if isinstance(cfg, dict) else None
        if not isinstance(gateway, dict):
            continue
        try:
            port = int(gateway.get("port") or port)
        except (TypeError, ValueError):
            pass
        auth = gateway.get("auth")
        if isinstance(auth, dict) and isinstance(auth.get("token"), str):
            token = auth["token"]
        return token, port
    return token, port


def _port_open(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.5)
        return sock.connect_ex(("127.0.0.1", port)) == 0


def _wait_port(port: int, timeout: float) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if _port_open(port):
            return True
        time.sleep(0.25)
    return False


def _run_openclaw_with_gateway(bin_name: str, extra: list[str], env: dict, profile: str | None = None) -> int:
    token, port = _openclaw_gateway_info(profile)
    gateway = None
    if not _port_open(port):
        gateway_cmd = [bin_name]
        if profile:
            gateway_cmd += ["--profile", profile]
        gateway_cmd += ["gateway", "run", "--force"]
        gateway = subprocess.Popen(
            gateway_cmd,
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if not _wait_port(port, 30):
            gateway.terminate()
            try:
                gateway.wait(timeout=5)
            except subprocess.TimeoutExpired:
                gateway.kill()
            print(f"openclaw gateway did not start on 127.0.0.1:{port}", file=sys.stderr)
            return 1

    cmd = [bin_name]
    if profile:
        cmd += ["--profile", profile]
    cmd += extra
    if token and "--token" not in extra and not any(a.startswith("--token=") for a in extra):
        cmd += ["--token", token]
    if "--url" not in extra and not any(a.startswith("--url=") for a in extra):
        cmd += ["--url", f"ws://127.0.0.1:{port}"]

    try:
        return subprocess.run(cmd, env=env).returncode
    finally:
        if gateway is not None:
            gateway.terminate()
            try:
                gateway.wait(timeout=5)
            except subprocess.TimeoutExpired:
                gateway.kill()


