        sys.exit(
            "hermes not found in PATH. Install options: "
            "https://hermes-agent.nousresearch.com/docs/getting-started/installation/"
        )
    model = require_model()
    if args.install:
        _install_hermes_global(model)
        return
    hermes_home = _prepare_hermes_home(model)
