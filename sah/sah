# packaged desktop app is already installed. Mirrors Ollama's HermesDesktop
# (cmd/launch/hermes.go), which embeds Hermes and reuses its Configure/Paths.

_HERMES_DESKTOP_BUILD_FLAGS = ("--skip-build", "--source", "--build-only", "--help", "-h")


def cmd_hermes_desktop(args) -> None:
    if args.status:
        _status_hermes_global()
        return
    if args.restore:
        _restore_client_file("hermes", _hermes_config_path())
        return
