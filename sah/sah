}


def _split_codex_exec_prompt(args: list[str]) -> tuple[list[str], str | None]:
    prompt_idx: int | None = None
    skip_next = False
    for idx, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue
        if arg in _CODEX_EXEC_OPTIONS_WITH_VALUE:
            skip_next = True
            continue
        if arg.startswith("-"):
            continue
        prompt_idx = idx
    if prompt_idx is None:
        return args, None
    out = [*args[:prompt_idx], *args[prompt_idx + 1:]]
    return out, args[prompt_idx]


def _augment_codex_pdf_text(text: str) -> str:
    """Codex has --image but no generic --file flag. For `codex exec` prompts
    that mention local PDFs, append extracted text so the model can read them
    without relying on a tool-call turn through the Responses API.
    """
    if ".pdf" not in text.lower():
        return text
    attachments = _pdf_attachments_for_text(text)
    if not attachments:
        return text
    text = _replace_pdf_paths_for_codex(text)
    return text.rstrip() + "\n\n" + "\n\n".join(attachments)


def _replace_pdf_paths_for_codex(text: str) -> str:
    return re.sub(
        r"(?<!\S)(?:'[^']+\.pdf'|\"[^\"]+\.pdf\"|\S+\.pdf)",
        "the extracted PDF text below",
        text,
        flags=re.IGNORECASE,
    )


def _pdf_attachments_for_text(text: str) -> list[str]:
    attachments: list[str] = []
    seen: set[str] = set()
    for raw in re.findall(r"(?<!\S)(?:'([^']+\.pdf)'|\"([^\"]+\.pdf)\"|(\S+\.pdf))", text, re.IGNORECASE):
        path_text = next((p for p in raw if p), "")
        path = Path(path_text).expanduser()
        if not path.is_absolute():
            path = (Path.cwd() / path).resolve()
        key = str(path)
        if key in seen or not path.is_file():
            continue
        seen.add(key)
        pdf_text = _extract_pdf_text(path)
        if pdf_text:
            attachments.append(f"[Extracted PDF text]\n{pdf_text}")
    return attachments


def _extract_pdf_text(path: Path) -> str:
    if not shutil.which("pdftotext"):
        return ""
    try:
        proc = subprocess.run(
            ["pdftotext", "-layout", str(path), "-"],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=30,
        )
    except subprocess.TimeoutExpired:
        return ""
    if proc.returncode != 0:
        return ""
    return proc.stdout.strip()


def _ensure_codex_profile() -> None:
    """Patch ~/.codex/config.toml with a [profiles.sah] section."""
    codex_dir = Path.home() / ".codex"
    codex_dir.mkdir(parents=True, exist_ok=True)
    cfg = codex_dir / "config.toml"
    base = api_base().rstrip("/") + "/"

    sections = [
        (
            "[profiles.sah]",
            [
                f'openai_base_url = "{base}"',
                'forced_login_method = "api"',
                'model_provider = "sah"',
            ],
        ),
        (
            "[model_providers.sah]",
            [
                'name = "Spark AI Hub"',
                f'base_url = "{base}"',
            ],
        ),
    ]

    text = cfg.read_text() if cfg.is_file() else ""
    for header, lines in sections:
        block = "\n".join([header, *lines]) + "\n"
        idx = text.find(header)
        if idx >= 0:
            rest = text[idx + len(header):]
            end = rest.find("\n[")
            if end >= 0:
                text = text[:idx] + block + rest[end + 1:]
            else:
                text = text[:idx] + block
        else:
            if text and not text.endswith("\n"):
                text += "\n"
            if text:
                text += "\n"
            text += block
    _validate_toml_text(text, cfg)
    _write_text_atomic(cfg, text)


def cmd_hermes(args) -> None:
    if args.status:
        _status_hermes_global()
        return
    if args.restore:
        _restore_client_file("hermes", _hermes_config_path())
        return
    if not shutil.which("hermes"):
        sys.exit(
            "hermes not found in PATH. Install options: "
            "https://hermes-agent.nousresearch.com/docs/getting-started/installation/"
        )
    model = require_model()
    if args.install:
        _install_hermes_global(model)
        return
    hermes_home = _prepare_hermes_home(model)
    env = {
        **os.environ,
        "HERMES_HOME": str(hermes_home),
