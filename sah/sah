#!/usr/bin/env python3
"""sah — Spark AI Hub launcher.

One command on each laptop. `sah opencode` launches OpenCode wired to
whatever LLM the Hub is currently serving. `sah codex` does the same for
Codex. `sah env` / `sah info` print connection details for any other
OpenAI-compatible client (Zed, Cursor, Continue, Chatbox, etc.).

Hub URL discovery, in order: --hub flag, $SAH_HUB, ~/.config/sah/hub,
http://192.168.3.16:9000 (default).
"""
from __future__ import annotations

import argparse
import json
import os
import shutil
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request
import uuid
from pathlib import Path

DEFAULT_HUB = "http://192.168.3.16:9000"
CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "sah"
CONFIG_FILE = CONFIG_DIR / "hub"


def hub_url() -> str:
    if v := os.environ.get("SAH_HUB"):
        return v.rstrip("/")
    if CONFIG_FILE.is_file():
        v = CONFIG_FILE.read_text().strip()
        if v:
            return v.rstrip("/")
    return DEFAULT_HUB


def api_base() -> str:
    return f"{hub_url()}/v1"


def current_model() -> str | None:
    info = current_model_info()
    return info.get("id") if info else None


def current_model_info() -> dict | None:
    try:
        with urllib.request.urlopen(f"{api_base()}/models", timeout=2) as r:
            data = json.loads(r.read())
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        return None
    items = data.get("data") or []
    return items[0] if items else None


def require_model() -> str:
    m = current_model()
    if not m:
        sys.exit(
            f"No model is running on {hub_url()}.\n"
            f"Launch one from the Spark AI Hub web UI first."
        )
    return m


# ---------- commands ----------

def cmd_info(_args) -> None:
    m = current_model()
    print(f"Hub:           {hub_url()}")
    print(f"OpenAI base:   {api_base()}")
    print(f"Anthropic base:{hub_url()}")
    print(f"API key:       sah  (any value works)")
    print(f"Current model: {m or '(none — launch one in the Hub)'}")


def cmd_env(args) -> None:
    base = hub_url() if args.anthropic else api_base()
    if args.anthropic:
        print(f"export ANTHROPIC_BASE_URL={base}")
        print(f"export ANTHROPIC_AUTH_TOKEN=sah")
    else:
        print(f"export OPENAI_BASE_URL={base}")
        print(f"export OPENAI_API_KEY=sah")


def cmd_set_hub(args) -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(args.url.rstrip("/") + "\n")
    print(f"Hub set to {args.url}")


def cmd_opencode(args) -> None:
    if not shutil.which("opencode"):
        sys.exit("opencode not found in PATH. Install: https://opencode.ai")
    model = require_model()
    config = {
        "$schema": "https://opencode.ai/config.json",
        "provider": {
            "sah": {
                "npm": "@ai-sdk/openai-compatible",
                "name": "Spark AI Hub",
                "options": {"baseURL": api_base()},
                "models": {model: {"name": model}},
            }
        },
        "model": f"sah/{model}",
    }
    env = {**os.environ, "OPENCODE_CONFIG_CONTENT": json.dumps(config)}
    os.execvpe("opencode", ["opencode", *args.passthrough], env)


def cmd_codex(args) -> None:
    if not shutil.which("codex"):
        sys.exit("codex not found in PATH. Install: npm install -g @openai/codex")
    info = current_model_info()
    if not info:
        sys.exit(
            f"No model is running on {hub_url()}.\n"
            f"Launch one from the Spark AI Hub web UI first."
        )
    model = info["id"]
    _ensure_codex_profile()
    catalog_path = _write_codex_catalog(model, info)
    env = {**os.environ, "OPENAI_API_KEY": "sah"}
    cmd = ["codex", "--profile", "sah", "-m", model]
    if catalog_path:
        cmd += ["-c", f'model_catalog_json="{catalog_path}"']
    elif ctx := info.get("max_model_len"):
        cmd += ["-c", f"model_context_window={int(ctx)}"]
    cmd += args.passthrough
    os.execvpe("codex", cmd, env)


def _write_codex_catalog(model: str, info: dict) -> str | None:
    """Fetch the catalog template from the Hub, repoint to the live model,
    write to ~/.config/sah/codex-catalog.json. Returns the absolute path or None.
    """
    try:
        with urllib.request.urlopen(f"{hub_url()}/sah/codex-model-template.json", timeout=2) as r:
            tpl = json.loads(r.read())
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        return None
    if not (tpl.get("models") and isinstance(tpl["models"], list)):
        return None
    entry = tpl["models"][0]
    entry["slug"] = model
    entry["display_name"] = model
    if ctx := info.get("max_model_len"):
        entry["context_window"] = int(ctx)
        entry["max_context_window"] = int(ctx)
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    out = CONFIG_DIR / "codex-catalog.json"
    out.write_text(json.dumps(tpl))
    return str(out)


def _ensure_codex_profile() -> None:
    """Patch ~/.codex/config.toml with a [profiles.sah] section."""
    codex_dir = Path.home() / ".codex"
    codex_dir.mkdir(parents=True, exist_ok=True)
    cfg = codex_dir / "config.toml"
    base = api_base().rstrip("/") + "/"

    sections = [
        (
            "[profiles.sah]",
            [
                f'openai_base_url = "{base}"',
                'forced_login_method = "api"',
                'model_provider = "sah"',
            ],
        ),
        (
            "[model_providers.sah]",
            [
                'name = "Spark AI Hub"',
                f'base_url = "{base}"',
            ],
        ),
    ]

    text = cfg.read_text() if cfg.is_file() else ""
    for header, lines in sections:
        block = "\n".join([header, *lines]) + "\n"
        idx = text.find(header)
        if idx >= 0:
            rest = text[idx + len(header):]
            end = rest.find("\n[")
            if end >= 0:
                text = text[:idx] + block + rest[end + 1:]
            else:
                text = text[:idx] + block
        else:
            if text and not text.endswith("\n"):
                text += "\n"
            if text:
                text += "\n"
            text += block
    cfg.write_text(text)


def cmd_hermes(args) -> None:
    if not shutil.which("hermes"):
        sys.exit("hermes not found in PATH. Install: https://github.com/NousResearch/hermes-agent")
    model = require_model()
    # Hermes reads model.base_url from config.yaml (no CLI flag for it), so
    # point it at a sah-managed HERMES_HOME with a freshly-written config that
    # targets the Hub's OpenAI-compatible endpoint. Isolating HERMES_HOME
    # keeps the user's main hermes profile (sessions, skills, auth) untouched.
    hermes_home = CONFIG_DIR / "hermes-home"
    hermes_home.mkdir(parents=True, exist_ok=True)
    cfg = (
        f"model:\n"
        f"  default: {model}\n"
        f"  provider: custom\n"
        f"  base_url: {api_base()}\n"
        f"toolsets:\n"
        f"  - hermes-cli\n"
    )
    (hermes_home / "config.yaml").write_text(cfg)
    env = {
        **os.environ,
        "HERMES_HOME": str(hermes_home),
        "OPENAI_API_KEY": "sah",
        "OPENAI_BASE_URL": api_base(),
    }
    extra = args.passthrough
    if extra and extra[0] == "--":
        extra = extra[1:]
    os.execvpe("hermes", ["hermes", *extra], env)


def cmd_qwen(args) -> None:
    if not shutil.which("qwen"):
        sys.exit("qwen not found in PATH. Install: npm install -g @qwen-code/qwen-code")
    model = require_model()
    qwen_home = _prepare_qwen_home(model)
    extra = _normalize_passthrough(args.passthrough)
    env = {
        **os.environ,
        "HOME": str(qwen_home),
        "OPENAI_API_KEY": "sah",
        "OPENAI_BASE_URL": api_base(),
    }
    cmd = [
        "qwen",
        "--auth-type", "openai",
        "--openai-base-url", api_base(),
        "--openai-api-key", "sah",
        "--model", model,
        *extra,
    ]
    os.execvpe("qwen", cmd, env)


_QWEN_CAPABILITIES_NOTE = """
## Multimodal capabilities (Spark AI Hub)

You are running on a Qwen 3.5/3.6 model served by Spark AI Hub. These models
are natively multimodal: when the `read_file` tool returns image or video
content, you can see and describe it directly. There is no separate "vision
model" to delegate to, and you do not need ffmpeg/ffprobe to inspect a video's
visual content.

When the user asks you to read or describe an image or video file:
- Just call `read_file` with the path. Do not refuse or claim to be text-only.
- Do not suggest extracting frames, running ffprobe, or asking the user to
  describe the file. Read it and answer.
- Supported extensions include common images (png, jpg, jpeg, gif, webp, bmp)
  and videos (mp4, mov, mkv, webm, avi).
""".strip()


def _qwen_modalities_for(model: str) -> dict:
    """Return modality flags for a Hub model.

    Qwen 3.5 / 3.6 instruct + VL families are natively multimodal (image +
    video). qwen-code's built-in defaults only flag `qwen3.5-plus` / `qwen-vl-*`
    as multimodal, so models served by the Hub (e.g. `Qwen/Qwen3.6-35B-A3B-FP8`)
    fall through to the text-only `^qwen` fallback and image/video reads get
    skipped client-side. Mark them multimodal here. Other models get an empty
    map (text-only).
    """
    norm = model.lower().replace("_", "-").split("/")[-1]
    if norm.startswith("qwen3.5") or norm.startswith("qwen3.6"):
        return {"image": True, "video": True}
    if "-vl-" in norm or norm.endswith("-vl") or "vision" in norm:
        return {"image": True, "video": True}
    return {}


def _prepare_qwen_home(model: str) -> Path:
    """Build an isolated HOME for `sah qwen` that shares everything with plain
    `qwen` *except* settings.json.

    qwen-code derives its config dir from `os.homedir()`. We point HOME at a
    sah-managed dir whose `.qwen/` is a mirror of the real `~/.qwen/`: every
    child (skills, projects, oauth_creds.json, todos, tmp, …) is symlinked to
    the real path, so reads and writes bleed through transparently. Only
    settings.json is materialized fresh — copied from the real one and
    overridden with our auth/model/modelProviders bits — so we never alter the
    user's real settings file.
    """
    home = CONFIG_DIR / "qwen-home"
    qwen_dir = home / ".qwen"
    qwen_dir.mkdir(parents=True, exist_ok=True)

    # Files we materialize ourselves (must not be symlinked through to the real
    # ~/.qwen): settings.json carries auth/modelProvider overrides, QWEN.md
    # carries the capability addendum.
    OWNED = {"settings.json", "QWEN.md"}

    real_qwen = Path.home() / ".qwen"
    if real_qwen.is_dir():
        existing = {p.name: p for p in qwen_dir.iterdir()}
        wanted = {p.name for p in real_qwen.iterdir() if p.name not in OWNED}
        for name, link in existing.items():
            if name in OWNED:
                continue
            if link.is_symlink() and name not in wanted:
                link.unlink()
        for item in real_qwen.iterdir():
            if item.name in OWNED:
                continue
            link = qwen_dir / item.name
            target = item.resolve()
            if link.is_symlink():
                if Path(os.readlink(link)) == target:
                    continue
                link.unlink()
            elif link.exists():
                continue  # leave non-symlink user data alone
            link.symlink_to(target)

    # Synthesize ~/.qwen/QWEN.md inside the isolated home: import the user's
    # real one (if any) so their global memory still applies, then append a
    # brief capability note. Without this, Qwen3.5/3.6 served via OpenAI-compat
    # don't realize they can read image/video files and refuse — `read_file`
    # has the modality flag set, but the model's prior keeps insisting "I'm
    # text-only" until the user argues with it.
    qwen_md_lines = []
    real_qwen_md = real_qwen / "QWEN.md"
    if real_qwen_md.is_file():
        qwen_md_lines.append(f"@{real_qwen_md}")
        qwen_md_lines.append("")
    qwen_md_lines.append(_QWEN_CAPABILITIES_NOTE.strip())
    qwen_md_lines.append("")
    (qwen_dir / "QWEN.md").write_text("\n".join(qwen_md_lines))

    base: dict = {}
    real_settings = real_qwen / "settings.json"
    if real_settings.is_file():
        try:
            loaded = json.loads(real_settings.read_text())
            if isinstance(loaded, dict):
                base = loaded
        except json.JSONDecodeError:
            pass

    base.setdefault("$version", 3)
    env_block = base.get("env") if isinstance(base.get("env"), dict) else {}
    env_block["OPENAI_API_KEY"] = "sah"
    base["env"] = env_block

    sec = base.get("security") if isinstance(base.get("security"), dict) else {}
    auth = sec.get("auth") if isinstance(sec.get("auth"), dict) else {}
    auth["selectedType"] = "openai"
    sec["auth"] = auth
    base["security"] = sec

    model_block = base.get("model") if isinstance(base.get("model"), dict) else {}
    model_block["name"] = model
    base["model"] = model_block

    providers = base.get("modelProviders") if isinstance(base.get("modelProviders"), dict) else {}
    openai_list = providers.get("openai") if isinstance(providers.get("openai"), list) else []
    entry = {
        "id": model,
        "name": f"Spark AI Hub · {model}",
        "baseUrl": api_base(),
        "envKey": "OPENAI_API_KEY",
        "generationConfig": {"modalities": _qwen_modalities_for(model)},
    }
    openai_list = [p for p in openai_list if not (isinstance(p, dict) and p.get("id") == model)]
    openai_list.insert(0, entry)
    providers["openai"] = openai_list
    base["modelProviders"] = providers

    (qwen_dir / "settings.json").write_text(json.dumps(base, indent=2) + "\n")
    return home


def cmd_openclaw(args) -> None:
    bin_name = shutil.which("openclaw") or shutil.which("clawdbot")
    if not bin_name:
        sys.exit("openclaw not found in PATH. Install: npm install -g openclaw@latest")
    info = current_model_info()
    if not info:
        sys.exit(
            f"No model is running on {hub_url()}.\n"
            f"Launch one from the Spark AI Hub web UI first."
        )
    model = info["id"]
    _ensure_openclaw_config(model, info)
    extra = _normalize_passthrough(args.passthrough)
    if not extra:
        extra = ["tui"]
    env = _openclaw_env()
    if extra[0] in {"tui", "terminal"} and "--local" not in extra:
        sys.exit(_run_openclaw_with_gateway(bin_name, extra, env))
    os.execvpe(bin_name, [bin_name, *extra], env)


def _normalize_passthrough(args: list[str]) -> list[str]:
    if args and args[0] == "--":
        return args[1:]
    return args


def _model_context_window(info: dict, default: int = 32768) -> int:
    try:
        ctx = int(info.get("max_model_len") or 0)
    except (TypeError, ValueError):
        ctx = 0
    return ctx if ctx > 0 else default


def _openclaw_config_paths() -> tuple[Path, Path]:
    return (
        Path.home() / ".openclaw" / "openclaw.json",
        Path.home() / ".clawdbot" / "clawdbot.json",
    )


def _ensure_openclaw_config(model: str, info: dict) -> None:
    config_path, legacy_path = _openclaw_config_paths()
    if not config_path.is_file() and not legacy_path.is_file():
        _openclaw_onboard(model)

    source = config_path if config_path.is_file() else legacy_path
    config = _read_json(source)
    config_path.parent.mkdir(parents=True, exist_ok=True)

    models_section = config.setdefault("models", {})
    if not isinstance(models_section, dict):
        models_section = {}
        config["models"] = models_section
    models_section.setdefault("mode", "merge")
    providers = models_section.setdefault("providers", {})
    if not isinstance(providers, dict):
        providers = {}
        models_section["providers"] = providers

    provider = providers.setdefault("sah", {})
    if not isinstance(provider, dict):
        provider = {}
        providers["sah"] = provider
    provider["baseUrl"] = api_base()
    provider["apiKey"] = "sah"
    provider["api"] = "openai-completions"

    model_entry = {
        "id": model,
        "name": model,
        "api": "openai-completions",
        "input": ["text"],
        "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
        "contextWindow": _model_context_window(info),
        "maxTokens": min(8192, _model_context_window(info)),
        "compat": {
            "supportsDeveloperRole": False,
            "supportsUsageInStreaming": True,
            "supportsStrictMode": False,
        },
    }
    existing = provider.get("models") if isinstance(provider.get("models"), list) else []
    provider["models"] = [
        *(m for m in existing if not (isinstance(m, dict) and m.get("id") == model)),
        model_entry,
    ]

    agents = config.setdefault("agents", {})
    if not isinstance(agents, dict):
        agents = {}
        config["agents"] = agents
    defaults = agents.setdefault("defaults", {})
    if not isinstance(defaults, dict):
        defaults = {}
        agents["defaults"] = defaults
    model_config = defaults.setdefault("model", {})
    if not isinstance(model_config, dict):
        model_config = {}
        defaults["model"] = model_config
    model_config["primary"] = f"sah/{model}"

    cfg_models = defaults.setdefault("models", {})
    if isinstance(cfg_models, dict):
        cfg_models[f"sah/{model}"] = cfg_models.get(f"sah/{model}", {})

    config_path.write_text(json.dumps(config, indent=2) + "\n")
    _clear_openclaw_session_model_override(model)


def _openclaw_onboard(model: str) -> None:
    bin_name = shutil.which("openclaw") or shutil.which("clawdbot")
    cmd = [
        bin_name,
        "onboard",
        "--non-interactive",
        "--accept-risk",
        "--auth-choice", "custom-api-key",
        "--custom-provider-id", "sah",
        "--custom-base-url", api_base(),
        "--custom-api-key", "sah",
        "--custom-model-id", model,
        "--custom-compatibility", "openai",
        "--skip-health",
        "--skip-channels",
        "--skip-skills",
        "--skip-ui",
        "--no-install-daemon",
    ]
    result = subprocess.run(cmd, env=_openclaw_env())
    if result.returncode != 0:
        sys.exit("openclaw onboarding failed. Try running: openclaw onboard")


def _clear_openclaw_session_model_override(model: str) -> None:
    path = Path.home() / ".openclaw" / "agents" / "main" / "sessions" / "sessions.json"
    if not path.is_file():
        return
    try:
        sessions = json.loads(path.read_text())
    except json.JSONDecodeError:
        return
    if not isinstance(sessions, dict):
        return
    changed = False
    for session in sessions.values():
        if not isinstance(session, dict):
            continue
        if session.get("modelOverride") and session.get("modelOverride") != model:
            session.pop("modelOverride", None)
            session.pop("providerOverride", None)
            changed = True
        if session.get("model") and session.get("model") != model:
            session["model"] = model
            changed = True
    if changed:
        path.write_text(json.dumps(sessions, indent=2) + "\n")


def _openclaw_gateway_info() -> tuple[str, int]:
    token = ""
    port = 18789
    for path in _openclaw_config_paths():
        cfg = _read_json(path)
        gateway = cfg.get("gateway") if isinstance(cfg, dict) else None
        if not isinstance(gateway, dict):
            continue
        try:
            port = int(gateway.get("port") or port)
        except (TypeError, ValueError):
            pass
        auth = gateway.get("auth")
        if isinstance(auth, dict) and isinstance(auth.get("token"), str):
            token = auth["token"]
        return token, port
    return token, port


def _port_open(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.settimeout(0.5)
        return sock.connect_ex(("127.0.0.1", port)) == 0


def _wait_port(port: int, timeout: float) -> bool:
    deadline = time.time() + timeout
    while time.time() < deadline:
        if _port_open(port):
            return True
        time.sleep(0.25)
    return False


def _run_openclaw_with_gateway(bin_name: str, extra: list[str], env: dict) -> int:
    token, port = _openclaw_gateway_info()
    gateway = None
    if not _port_open(port):
        gateway = subprocess.Popen(
            [bin_name, "gateway", "run", "--force"],
            env=env,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if not _wait_port(port, 30):
            gateway.terminate()
            try:
                gateway.wait(timeout=5)
            except subprocess.TimeoutExpired:
                gateway.kill()
            print(f"openclaw gateway did not start on 127.0.0.1:{port}", file=sys.stderr)
            return 1

    cmd = [bin_name, *extra]
    if token and "--token" not in extra and not any(a.startswith("--token=") for a in extra):
        cmd += ["--token", token]
    if "--url" not in extra and not any(a.startswith("--url=") for a in extra):
        cmd += ["--url", f"ws://127.0.0.1:{port}"]

    try:
        return subprocess.run(cmd, env=env).returncode
    finally:
        if gateway is not None:
            gateway.terminate()
            try:
                gateway.wait(timeout=5)
            except subprocess.TimeoutExpired:
                gateway.kill()


def _openclaw_env() -> dict:
    clear = {
        "ANTHROPIC_API_KEY",
        "ANTHROPIC_OAUTH_TOKEN",
        "OPENAI_API_KEY",
        "GEMINI_API_KEY",
        "MISTRAL_API_KEY",
        "GROQ_API_KEY",
        "XAI_API_KEY",
        "OPENROUTER_API_KEY",
    }
    env = {k: v for k, v in os.environ.items() if k not in clear}
    env["OPENAI_API_KEY"] = "sah"
    env["OPENAI_BASE_URL"] = api_base()
    env.setdefault(
        "OPENCLAW_PLUGIN_STAGE_DIR",
        str(Path.home() / ".openclaw" / "plugin-runtime-deps"),
    )
    return env


def cmd_claude(args) -> None:
    if not shutil.which("claude"):
        sys.exit("claude not found. Install: https://claude.com/code")
    model = require_model()
    extra = args.passthrough
    if extra and extra[0] == "--":
        extra = extra[1:]
    env = {
        **os.environ,
        "ANTHROPIC_BASE_URL": hub_url(),
        "ANTHROPIC_API_KEY": "",
        "ANTHROPIC_AUTH_TOKEN": "sah",
        "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": model,
        "ANTHROPIC_DEFAULT_SONNET_MODEL": model,
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": model,
        "CLAUDE_CODE_SUBAGENT_MODEL": model,
    }
    os.execvpe("claude", ["claude", "--model", model, *extra], env)


# ---------- claude-desktop ----------
#
# Architecture: Claude Desktop's Cowork 3p mode requires HTTPS gateway URLs
# (or http on 127.0.0.1). The Hub runs plain http on the LAN, so we install
# a tiny TCP forwarder on 127.0.0.1:9009 → Hub as a launchd agent. Claude
# Desktop sees a loopback URL and is happy.
#
# Schema mirrors Ollama's `ollama launch claude-desktop` (cmd/launch/claude_desktop.go):
# we set deploymentMode="3p" (or "1p" on restore), maintain a stable profile
# UUID, write the same gateway keys, and offer the same restore semantics.

SAH_PROFILE_ID = str(uuid.uuid5(uuid.NAMESPACE_DNS, "spark-ai-hub.sah"))
SAH_PROFILE_NAME = "Spark AI Hub"
SAH_TUNNEL_PORT = 9009
SAH_LAUNCH_LABEL = "ai.waxacabytes.sah-tunnel"

SAH_TUNNEL_SCRIPT = '''#!/usr/bin/env python3
"""sah-tunnel — TCP forwarder: 127.0.0.1:<port> -> <hub host:port>.

Lets Claude Desktop see a loopback URL while traffic actually goes to the
LAN Spark AI Hub. Plain TCP forwarding works for HTTP requests and SSE.
"""
import asyncio, sys, urllib.parse


async def _pipe(reader, writer):
    try:
        while True:
            data = await reader.read(65536)
            if not data:
                break
            writer.write(data)
            await writer.drain()
    except (ConnectionError, OSError):
        pass
    finally:
        try:
            writer.close()
        except Exception:
            pass


async def _handle(client_r, client_w, host, port):
    try:
        upstream_r, upstream_w = await asyncio.open_connection(host, port)
    except (ConnectionError, OSError):
        client_w.close()
        return
    await asyncio.gather(_pipe(client_r, upstream_w), _pipe(upstream_r, client_w))


async def _main():
    listen_port = int(sys.argv[1])
    hub = urllib.parse.urlparse(sys.argv[2])
    host = hub.hostname or "127.0.0.1"
    port = hub.port or (443 if hub.scheme == "https" else 80)
    server = await asyncio.start_server(
        lambda r, w: _handle(r, w, host, port), "127.0.0.1", listen_port
    )
    async with server:
        await server.serve_forever()


if __name__ == "__main__":
    asyncio.run(_main())
'''


def _cd_paths() -> dict:
    if sys.platform != "darwin":
        sys.exit(
            "sah claude-desktop is macOS-only. Anthropic does not ship a Linux "
            "build of Claude Desktop; run this on the Mac that has it installed."
        )
    home = Path.home()
    base = home / "Library/Application Support"
    return {
        "normal_dir": base / "Claude",
        "third_party_dir": base / "Claude-3p",
        "launch_agents": home / "Library/LaunchAgents",
        "tunnel_script": CONFIG_DIR / "sah-tunnel.py",
        "tunnel_log": CONFIG_DIR / "sah-tunnel.log",
        "plist": home / "Library/LaunchAgents" / f"{SAH_LAUNCH_LABEL}.plist",
    }


def _claude_app_path() -> Path | None:
    for cand in (Path("/Applications/Claude.app"), Path.home() / "Applications/Claude.app"):
        if cand.is_dir():
            return cand
    return None


def _require_claude_installed() -> None:
    if _claude_app_path() is None:
        sys.exit(
            "Claude Desktop is not installed. Install it from "
            "https://claude.ai/download, then re-run this command."
        )


def _read_json(path: Path) -> dict:
    if not path.is_file():
        return {}
    try:
        return json.loads(path.read_text()) or {}
    except json.JSONDecodeError:
        return {}


def _write_json(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n")


def _claude_pids() -> list[int]:
    r = subprocess.run(
        ["pgrep", "-f", "Claude.app/Contents/MacOS/Claude"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return []
    return [int(x) for x in r.stdout.split() if x.strip().isdigit()]


def _claude_running() -> bool:
    return bool(_claude_pids())


def _quit_claude() -> None:
    subprocess.run(
        ["osascript", "-e", 'tell application "Claude" to quit'],
        check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )


def _open_claude() -> None:
    subprocess.run(["open", "-a", "Claude"], check=False)


def _wait_claude_exit(timeout: float) -> bool:
    """Poll until no Claude PIDs remain. Print a single dot per second so the
    user sees progress without 50 dots/10s. Returns True if it actually exited.
    """
    import time as _t
    deadline = _t.time() + timeout
    last_dot = _t.time()
    while _t.time() < deadline:
        if not _claude_running():
            return True
        if _t.time() - last_dot >= 1.0:
            print(".", end="", flush=True)
            last_dot = _t.time()
        _t.sleep(0.1)
    return False


def _open_and_verify() -> None:
    """open -a Claude, then poll until it's running. Retry once if needed."""
    import time as _t
    _open_claude()
    for _ in range(20):  # up to 4s
        if _claude_running():
            return
        _t.sleep(0.2)
    _open_claude()


def _restart_claude(skip: bool) -> None:
    if skip:
        if _claude_running():
            print("Quit and reopen Claude Desktop for the change to take effect.")
        else:
            print("Open Claude Desktop when you're ready.")
        return
    if not _claude_running():
        print("Opening Claude Desktop...", end="", flush=True)
        _open_and_verify()
        print(" done.")
        return

    print("Restarting Claude Desktop", end="", flush=True)
    _quit_claude()
    _wait_claude_exit(30.0)
    # Brief settle so launch services releases the previous instance before
    # we ask for a new one.
    import time as _t
    _t.sleep(0.5)
    _open_and_verify()
    print(" done.")


def _install_tunnel(hub: str) -> None:
    p = _cd_paths()
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    p["tunnel_script"].write_text(SAH_TUNNEL_SCRIPT)
    p["tunnel_script"].chmod(0o755)

    plist = (
        '<?xml version="1.0" encoding="UTF-8"?>\n'
        '<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" '
        '"http://www.apple.com/DTDs/PropertyList-1.0.dtd">\n'
        '<plist version="1.0">\n'
        '<dict>\n'
        f'    <key>Label</key><string>{SAH_LAUNCH_LABEL}</string>\n'
        '    <key>ProgramArguments</key>\n'
        '    <array>\n'
        '        <string>/usr/bin/python3</string>\n'
        f'        <string>{p["tunnel_script"]}</string>\n'
        f'        <string>{SAH_TUNNEL_PORT}</string>\n'
        f'        <string>{hub}</string>\n'
        '    </array>\n'
        '    <key>RunAtLoad</key><true/>\n'
        '    <key>KeepAlive</key><true/>\n'
        f'    <key>StandardOutPath</key><string>{p["tunnel_log"]}</string>\n'
        f'    <key>StandardErrorPath</key><string>{p["tunnel_log"]}</string>\n'
        '</dict>\n'
        '</plist>\n'
    )
    p["plist"].parent.mkdir(parents=True, exist_ok=True)
    p["plist"].write_text(plist)

    # Reload to pick up any URL changes; ignore unload errors on first install.
    subprocess.run(["launchctl", "unload", str(p["plist"])],
                   check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["launchctl", "load", str(p["plist"])], check=False)

    # Wait until the tunnel actually accepts a connection. Claude Desktop probes
    # the gateway URL at startup and caches a failure if the port isn't ready;
    # without this gate, "sah claude-desktop" relaunches Claude before launchd
    # finishes binding the socket and the user sees ERR_CONNECTION_REFUSED.
    import socket as _s, time as _t
    deadline = _t.time() + 5
    while _t.time() < deadline:
        with _s.socket(_s.AF_INET, _s.SOCK_STREAM) as sock:
            sock.settimeout(0.2)
            try:
                sock.connect(("127.0.0.1", SAH_TUNNEL_PORT))
                return
            except OSError:
                _t.sleep(0.1)
    print(
        f"warning: tunnel on 127.0.0.1:{SAH_TUNNEL_PORT} did not come up within 5s; "
        f"check ~/.config/sah/sah-tunnel.log",
        file=sys.stderr,
    )


def _uninstall_tunnel() -> None:
    p = _cd_paths()
    if p["plist"].is_file():
        subprocess.run(["launchctl", "unload", str(p["plist"])],
                       check=False, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        p["plist"].unlink()
    if p["tunnel_script"].is_file():
        p["tunnel_script"].unlink()


def _set_deployment_mode(mode: str) -> None:
    p = _cd_paths()
    for d in (p["normal_dir"], p["third_party_dir"]):
        cfg_path = d / "claude_desktop_config.json"
        cfg = _read_json(cfg_path)
        if cfg.get("deploymentMode") == mode and cfg_path.is_file():
            continue
        cfg["deploymentMode"] = mode
        _write_json(cfg_path, cfg)


def _write_meta_entry() -> None:
    p = _cd_paths()
    meta_path = p["third_party_dir"] / "configLibrary/_meta.json"
    meta = _read_json(meta_path)
    entries = [e for e in (meta.get("entries") or []) if e.get("id") != SAH_PROFILE_ID]
    entries.append({"id": SAH_PROFILE_ID, "name": SAH_PROFILE_NAME})
    meta["entries"] = entries
    meta["appliedId"] = SAH_PROFILE_ID
    _write_json(meta_path, meta)


def _restore_meta_entry() -> None:
    p = _cd_paths()
    meta_path = p["third_party_dir"] / "configLibrary/_meta.json"
    if not meta_path.is_file():
        return
    meta = _read_json(meta_path)
    if not meta:
        return
    changed = False
    if meta.get("appliedId") == SAH_PROFILE_ID:
        meta.pop("appliedId", None)
        changed = True
    entries = meta.get("entries") or []
    new_entries = [e for e in entries if e.get("id") != SAH_PROFILE_ID]
    if len(new_entries) != len(entries):
        meta["entries"] = new_entries
        changed = True
    if changed:
        _write_json(meta_path, meta)


def _write_gateway_profile() -> None:
    p = _cd_paths()
    profile_path = p["third_party_dir"] / f"configLibrary/{SAH_PROFILE_ID}.json"
    cfg = _read_json(profile_path)
    cfg["inferenceProvider"] = "gateway"
    cfg["inferenceGatewayBaseUrl"] = f"http://127.0.0.1:{SAH_TUNNEL_PORT}"
    cfg["inferenceGatewayApiKey"] = "sah"
    cfg["inferenceGatewayAuthScheme"] = "bearer"
    cfg["disableDeploymentModeChooser"] = True
    cfg.pop("inferenceModels", None)
    _write_json(profile_path, cfg)


def _restore_gateway_profile() -> None:
    """Strip the gateway keys from the SAH profile rather than deleting it.

    Mirrors Ollama. Deleting the file outright was leaving Claude Desktop in
    a broken "applied profile is gone" state on the next launch — presenting
    as a logged-out 3p screen even though we'd flipped deploymentMode to 1p.
    """
    p = _cd_paths()
    profile_path = p["third_party_dir"] / f"configLibrary/{SAH_PROFILE_ID}.json"
    if not profile_path.is_file():
        return
    cfg = _read_json(profile_path)
    if not cfg:
        return
    cfg["disableDeploymentModeChooser"] = False
    for k in ("inferenceProvider", "inferenceGatewayBaseUrl",
              "inferenceGatewayAuthScheme", "inferenceModels"):
        cfg.pop(k, None)
    _write_json(profile_path, cfg)


def _status() -> None:
    p = _cd_paths()
    app = _claude_app_path()
    print(f"Claude Desktop:  {'installed at ' + str(app) if app else 'NOT installed'}")
    if not app:
        return

    cfg = _read_json(p["third_party_dir"] / "claude_desktop_config.json")
    mode = cfg.get("deploymentMode", "1p (default)")
    profile = _read_json(p["third_party_dir"] / f"configLibrary/{SAH_PROFILE_ID}.json")
    meta = _read_json(p["third_party_dir"] / "configLibrary/_meta.json")
    applied = meta.get("appliedId") == SAH_PROFILE_ID
    gateway_url = profile.get("inferenceGatewayBaseUrl", "—")
    plist_loaded = p["plist"].is_file()

    sah_active = (
        mode == "3p"
        and applied
        and profile.get("inferenceProvider") == "gateway"
        and plist_loaded
    )
    print(f"Deployment mode: {mode}")
    print(f"SAH profile:     {'APPLIED' if sah_active else 'not applied'}")
    print(f"Gateway URL:     {gateway_url}")
    print(f"Tunnel agent:    {'loaded' if plist_loaded else 'not installed'} ({p['plist']})")
    print(f"Claude running:  {'yes' if _claude_running() else 'no'}")


def cmd_claude_desktop(args) -> None:
    """Wire Claude Desktop's Cowork 3p mode to the Hub via a loopback proxy.

    Install (default): drops a launchd-managed TCP forwarder on 127.0.0.1
    pointing at the Hub, writes a 3p gateway profile, sets deploymentMode=3p,
    and restarts Claude Desktop.

    Restore (--restore): tears down the SAH profile, flips deploymentMode=1p
    (Anthropic-account mode), and restarts Claude Desktop. Mirrors Ollama's
    `--restore` semantics.

    Status (--status): print whether SAH is currently wired to Claude Desktop.

    Use --no-restart to skip the automatic Claude Desktop restart.
    """
    _cd_paths()  # exits early on non-darwin

    if args.status:
        _status()
        return

    _require_claude_installed()

    if args.restore:
        # Order matches Ollama: flip deploymentMode first, then unwind the
        # gateway profile + meta entry. Claude Desktop reads deploymentMode
        # at launch and routes everything else off that.
        _set_deployment_mode("1p")
        _restore_meta_entry()
        _restore_gateway_profile()
        _uninstall_tunnel()
        print("Spark AI Hub disconnected from Claude Desktop.")
        _restart_claude(skip=args.no_restart)
        return

    hub = hub_url()
    _install_tunnel(hub)
    _write_gateway_profile()
    _write_meta_entry()
    _set_deployment_mode("3p")
    print("Spark AI Hub wired to Claude Desktop.")
    print(f"  Local proxy:  127.0.0.1:{SAH_TUNNEL_PORT} → {hub}")
    print(f"  Restore with: sah claude-desktop --restore")
    _restart_claude(skip=args.no_restart)


# ---------- entrypoint ----------

def main() -> None:
    p = argparse.ArgumentParser(prog="sah", description="Spark AI Hub launcher")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("info", help="Show Hub URL and current model")
    sp.set_defaults(func=cmd_info)

    sp = sub.add_parser("env", help="Print export lines for OPENAI_* / ANTHROPIC_*")
    sp.add_argument("--anthropic", action="store_true", help="Anthropic-shaped env vars")
    sp.set_defaults(func=cmd_env)

    sp = sub.add_parser("set-hub", help="Persist Hub URL to ~/.config/sah/hub")
    sp.add_argument("url")
    sp.set_defaults(func=cmd_set_hub)

    sp = sub.add_parser("opencode", help="Launch OpenCode wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_opencode)

    sp = sub.add_parser("codex", help="Launch Codex wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_codex)

    sp = sub.add_parser("hermes", help="Launch Hermes Agent wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_hermes)

    sp = sub.add_parser("qwen", help="Launch Qwen Code wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_qwen)

    sp = sub.add_parser("openclaw", aliases=["clawdbot", "moltbot"],
                        help="Launch OpenClaw wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_openclaw)

    sp = sub.add_parser("claude", help="Launch Claude Code wired to the Hub")
    sp.add_argument("passthrough", nargs=argparse.REMAINDER)
    sp.set_defaults(func=cmd_claude)

    sp = sub.add_parser("claude-desktop", help="Wire Claude Desktop to the Hub")
    g = sp.add_mutually_exclusive_group()
    g.add_argument("--restore", action="store_true",
                   help="Restore Claude Desktop to the usual Anthropic profile")
    g.add_argument("--status", action="store_true",
                   help="Show whether SAH is currently wired to Claude Desktop")
    sp.add_argument("--no-restart", action="store_true",
                    help="Skip the automatic Claude Desktop restart")
    sp.set_defaults(func=cmd_claude_desktop)

    args, extras = p.parse_known_args()
    if hasattr(args, "passthrough"):
        args.passthrough = [*extras, *args.passthrough]
    elif extras:
        p.error(f"unrecognized arguments: {' '.join(extras)}")
    args.func(args)


if __name__ == "__main__":
    main()
