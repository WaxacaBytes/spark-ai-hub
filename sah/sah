_LABEL_W = 19  # one width for every "<label>: <value>" line printed by sah


def _kv(label: str, value: str) -> None:
    print(f"{(label + ':').ljust(_LABEL_W)} {value}")


def _print_wired(name: str, bin_name: str, config_path: Path, extras: tuple[tuple[str, str], ...] = ()) -> None:
    print(f"{name} wired to Spark AI Hub.")
    _kv("  Config", str(config_path))
    for k, v in extras:
        _kv(f"  {k}", v)
    print(f"  Plain `{bin_name}` will use the Hub until you run: sah {bin_name} --restore")


def _print_status(name: str, bin_name: str, config_path: Path, wired: bool, extras: tuple[tuple[str, str], ...] = ()) -> None:
    _kv(f"{name} config", str(config_path))
    _kv("SAH backup", "present" if _client_backup_path(bin_name).is_file() else "not present")
    _kv(f"Plain {bin_name}", "wired to Spark AI Hub" if wired else "not wired to Spark AI Hub")
    for k, v in extras:
        _kv(k, v)


def _print_table(rows: list[dict], columns: list[tuple[str, str]]) -> None:
    widths = {}
    for key, title in columns:
        widths[key] = max(len(title), *(len(str(row.get(key, ""))) for row in rows))
    print("  ".join(title.ljust(widths[key]) for key, title in columns))
    print("  ".join("-" * widths[key] for key, _title in columns))
    for row in rows:
        print("  ".join(str(row.get(key, "")).ljust(widths[key]) for key, _title in columns))


def _write_text_atomic(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp-{os.getpid()}")
    tmp.write_text(text)
    tmp.replace(path)


def _write_json_atomic(path: Path, data: dict) -> None:
    _write_text_atomic(path, json.dumps(data, indent=2) + "\n")


